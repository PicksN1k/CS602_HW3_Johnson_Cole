<b>Course Name Query </b>
{{query}}

<p></p>

{{#if courses.length}}

<ul>
{{#each courses}}
    <li>
        <a href="/describe/{{id}}">
            {{courseId}}
        </a>
        - {{courseName}}
        (<a href="/coordinator/{{Coordinator.id}}">
            Contact Prof. {{Coordinator.lastName}}
        </a>)
    </li>
{{/each}}
</ul>

{{else}}

<h3>404 - Not Found</h3>

{{/if}}